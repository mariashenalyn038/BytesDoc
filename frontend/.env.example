# Base URL for the BytesDoc backend API, including the /api suffix.
# Local dev: http://localhost:4000/api
# Production: https://<your-render-service>.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Supabase project credentials — needed by the /accept-invite page so it can
# read the invite tokens from the URL hash and set the user's password.
# Both are safe to expose to the browser (the anon key is the public key).
# Find them in Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
